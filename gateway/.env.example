# LiteLLM proxy auth
LITELLM_MASTER_KEY=change-me
LITELLM_SALT_KEY=change-me-too

# Redis
REDIS_URL=redis://redis:6379/0

# Primary upstream copied from local cc-switch template
UPSTREAM_1_BASE_URL=https://example.com/v1
UPSTREAM_1_API_KEY=replace-me
UPSTREAM_1_MODEL=example-model
UPSTREAM_1_TPM=120000
UPSTREAM_1_RPM=3000

# Optional additional upstreams
UPSTREAM_2_BASE_URL=
UPSTREAM_2_API_KEY=
UPSTREAM_2_MODEL=
UPSTREAM_2_TPM=
UPSTREAM_2_RPM=

# Semantic cache adjudicator
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_MODEL=gpt-4o-mini
SEMANTIC_CACHE_BASE_URL=
SEMANTIC_CACHE_API_KEY=
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_MAX_CANDIDATES=5

# Monitoring
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
